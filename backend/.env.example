# Copy to project root .env (parent of this folder) or set these in the environment.

# Neo4j (Aura)
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
# Use "neo4j" unless you created another database in Aura
NEO4J_DATABASE=neo4j

# LLM — pick one provider
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LLM_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: max rows passed from Cypher into the answer step
GRAPH_CYPHER_TOP_K=25
