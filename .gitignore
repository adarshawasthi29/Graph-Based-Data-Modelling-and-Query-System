# =========================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
.venv/
env/
.env/
Pipfile.lock

# Caches & Logs
*.log
.pytest_cache/
.mypy_cache/
.ruff_cache/

